NODE_ENV=development
PORT=4000
HOST=0.0.0.0
APP_NAME=Nosso Zelo API
APP_VERSION=1.0.0

DATABASE_URL=mysql://nossozelo:nossozelo@localhost:3306/nossozelo
JWT_SECRET=troque-por-uma-chave-com-pelo-menos-32-caracteres

FRONTEND_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:4000
API_URL=http://localhost:4000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Local usa lax. Em producao cross-site, use none ou deixe automatico com FRONTEND_URL/BACKEND_PUBLIC_URL corretos.
COOKIE_SAMESITE=lax

LOG_LEVEL=info
LOG_FORMAT=pretty
NOMINATIM_USER_AGENT=NossoZelo/1.0 (contato@nossozelo.com.br)
EXTERNAL_FETCH_TIMEOUT_MS=5000

RATE_LIMIT_STORE=memory
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=NossoZelo <no-reply@example.com>

PAYMENT_GATEWAY=disabled
ASAAS_ENVIRONMENT=sandbox
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_BILLING_TYPE=PIX
ASAAS_TIMEOUT_MS=60000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/nossozelo/login/social/google/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:4000/nossozelo/login/social/facebook/callback

ENABLE_ADMIN_CRUD=false
ENABLE_UPLOADS=false
UPLOAD_SCAN_MODE=disabled
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=15000
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_PUBLIC_BUCKET_NAME=
AWS_PRIVATE_BUCKET_NAME=

SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Administrador NossoZelo
SEED_ADMIN_CPF=
SEED_ADMIN_PHONE=
SEED_ADMIN_CEP=00000000
